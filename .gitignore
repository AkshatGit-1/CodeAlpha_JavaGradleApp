# Ignore Gradle project-specific cache directory
.gradle

# Ignore Gradle build output directory
build

# Ignore Kotlin plugin data
.kotlin

# ─── Gradle ────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ─── VS Code ───────────────────────────────────────────
.vscode/
*.code-workspace

# ─── IntelliJ IDEA ─────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr

# ─── OS Files ──────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Compiled Files ────────────────────────────────────
*.class
*.jar
*.war

# ─── Logs ──────────────────────────────────────────────
*.log
logs/
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar
